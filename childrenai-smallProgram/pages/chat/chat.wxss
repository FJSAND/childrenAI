.chat-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: var(--bg-canvas);
}

/* 顶部栏 */
.chat-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 32rpx;
  background: var(--card-solid);
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.chat-title { display: flex; align-items: center; gap: 16rpx; font-size: 32rpx; font-weight: 800; }
.chat-status { font-size: 22rpx; padding: 4rpx 16rpx; border-radius: var(--r-pill); background: var(--sky-soft); color: var(--sky); font-weight: 600; }
.chat-status.thinking { background: var(--sun-soft); color: #D97706; animation: pulse 1s infinite; }
@keyframes pulse { 0%,100%{ opacity:1; } 50%{ opacity:0.5; } }
.chat-actions-top { display: flex; gap: 16rpx; }
.action-btn { font-size: 36rpx; padding: 8rpx; }

/* 课程提示 */
.course-hint {
  padding: 12rpx 32rpx;
  background: var(--grape-soft);
  color: #6D28D9;
  font-size: 24rpx;
  font-weight: 600;
}

/* 消息区 */
.chat-messages {
  flex: 1;
  padding: 24rpx 32rpx;
  overflow-y: auto;
}

.msg-bubble {
  max-width: 80%;
  padding: 20rpx 28rpx;
  margin-bottom: 20rpx;
  font-size: 28rpx;
  line-height: 1.7;
  word-wrap: break-word;
  white-space: pre-wrap;
}
.msg-bubble.user {
  margin-left: auto;
  background: linear-gradient(135deg, var(--coral), #FF8E6B);
  color: #fff;
  border-radius: 32rpx 32rpx 8rpx 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(255,107,107,0.2);
}
.msg-bubble.ai {
  margin-right: auto;
  background: var(--card-solid);
  color: var(--ink);
  border-radius: 32rpx 32rpx 32rpx 8rpx;
  box-shadow: var(--shadow-card);
}
.msg-system {
  text-align: center;
  margin: 12rpx 0;
  font-size: 24rpx;
  color: var(--ink-light);
}
.msg-text { display: block; }

/* 代码块 */
.code-block {
  margin: 16rpx 0;
  border-radius: 16rpx;
  overflow: hidden;
  background: #1E1E2E;
}
.code-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 20rpx;
  background: #2D2D3F;
}
.code-lang {
  font-size: 22rpx;
  color: #A0A0C0;
  font-weight: 600;
  text-transform: uppercase;
}
.code-actions { display: flex; gap: 16rpx; }
.code-run-btn {
  font-size: 22rpx;
  color: #86EFAC;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  background: rgba(134,239,172,0.15);
  font-weight: 600;
}
.code-copy-btn {
  font-size: 22rpx;
  color: #7DD3FC;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  background: rgba(125,211,252,0.1);
}
.code-body {
  padding: 20rpx;
  max-height: 600rpx;
}
.code-text {
  font-size: 24rpx;
  color: #E0E0F0;
  font-family: 'Menlo', 'Courier New', monospace;
  line-height: 1.6;
  white-space: pre;
  display: block;
}

/* 思考中 */
.thinking-dots { color: var(--ink-light); font-size: 26rpx; }

/* 欢迎卡片 */
.hint-card {
  background: var(--card-solid);
  border-radius: var(--r-lg);
  padding: 40rpx;
  text-align: center;
  box-shadow: var(--shadow-card);
  margin: 40rpx 0;
}
.hint-title { font-size: 36rpx; font-weight: 800; margin-bottom: 16rpx; }
.hint-text { font-size: 26rpx; color: var(--ink-light); line-height: 1.8; }

/* 输入区 */
.input-area {
  display: flex;
  align-items: flex-end;
  gap: 16rpx;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: var(--card-solid);
  box-shadow: 0 -2rpx 8rpx rgba(0,0,0,0.04);
}
.chat-input {
  flex: 1;
  min-height: 56rpx;
  max-height: 200rpx;
  padding: 16rpx 24rpx;
  font-size: 28rpx;
  background: #F3F2F8;
  border-radius: var(--r-md);
  line-height: 1.6;
}
.send-btn {
  padding: 16rpx 28rpx;
  font-size: 26rpx;
  font-weight: 700;
  color: #fff;
  background: linear-gradient(135deg, var(--coral), #FF8E6B);
  border-radius: var(--r-md);
  flex-shrink: 0;
  white-space: nowrap;
  text-align: center;
  line-height: 1;
}
.send-btn.disabled { opacity: 0.4; pointer-events: none; }

/* API Key 弹窗 */
.api-modal { position: fixed; top: 0; left: 0; right: 0; bottom: 0; z-index: 999; display: flex; align-items: center; justify-content: center; }
.api-modal-mask { position: absolute; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.4); }
.api-modal-content { position: relative; width: 88%; background: var(--card-solid); border-radius: var(--r-lg); padding: 48rpx 32rpx; box-shadow: var(--shadow-float); box-sizing: border-box; }
.api-modal-title { font-size: 36rpx; font-weight: 800; text-align: center; margin-bottom: 32rpx; }
.api-input { width: 100%; padding: 24rpx 24rpx; border: 2rpx solid var(--border-soft); border-radius: var(--r-sm); font-size: 26rpx; background: #F8F7FC; box-sizing: border-box; }
.api-hint { font-size: 24rpx; color: var(--ink-light); margin-top: 16rpx; text-align: center; word-break: break-all; }
.api-save-btn { margin-top: 32rpx; background: linear-gradient(135deg, var(--coral), #FF8E6B); color: #fff; font-weight: 700; border-radius: var(--r-pill); border: none; }
.api-save-btn::after { border: none; }

