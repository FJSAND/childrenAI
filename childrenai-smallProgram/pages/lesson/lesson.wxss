.container {
  padding: 32rpx;
}

.lesson-badge {
  display: inline-block;
  padding: 8rpx 24rpx;
  border-radius: var(--r-pill);
  font-size: 24rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
}

.lesson-title {
  font-size: 40rpx;
  font-weight: 900;
  line-height: 1.3;
  color: var(--ink);
  margin-bottom: 32rpx;
}

.section {
  margin-bottom: 32rpx;
}
.section-header {
  font-size: 32rpx;
  font-weight: 800;
  color: var(--coral);
  margin-bottom: 16rpx;
}

.goal-card {
  background: var(--card-solid);
  padding: 24rpx 28rpx;
  border-radius: var(--r-sm);
  border-left: 8rpx solid var(--sky);
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.03);
  font-size: 28rpx;
  line-height: 1.7;
}

.prompt-card {
  background: linear-gradient(135deg, #2D2B42, #3D3B56);
  color: #E8E6F0;
  padding: 28rpx;
  border-radius: var(--r-md);
  font-size: 28rpx;
  line-height: 1.7;
  border: 2rpx solid rgba(167, 139, 250, 0.2);
  position: relative;
}
.prompt-text {
  display: block;
  word-wrap: break-word;
  white-space: pre-wrap;
}
.copy-btn {
  display: inline-block;
  margin-top: 16rpx;
  padding: 8rpx 20rpx;
  background: rgba(255,255,255,0.1);
  border: 1rpx solid rgba(255,255,255,0.15);
  border-radius: var(--r-sm);
  color: #A78BFA;
  font-size: 24rpx;
}

.step-card {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  background: var(--card-solid);
  padding: 20rpx 24rpx;
  border-radius: var(--r-sm);
  margin-bottom: 12rpx;
  border-left: 6rpx solid var(--sky);
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.03);
}
.step-num {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: var(--sky-soft);
  color: var(--sky);
  font-size: 24rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.step-text {
  font-size: 28rpx;
  line-height: 1.6;
  color: var(--ink);
}

.checklist-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 12rpx 0;
  font-size: 28rpx;
}
.check-icon {
  color: var(--sky);
  font-weight: 700;
  font-size: 32rpx;
}

.btn-practice {
  display: block;
  margin: 40rpx auto 0;
  padding: 24rpx 56rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: #fff;
  background: linear-gradient(135deg, #FF6B6B, #FF8E6B, #FFE66D);
  border-radius: var(--r-pill);
  box-shadow: 0 8rpx 28rpx rgba(255, 107, 107, 0.3);
  border: none;
}
.btn-practice::after { border: none; }

