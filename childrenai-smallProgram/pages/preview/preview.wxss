.preview-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #fff;
}
.preview-toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 24rpx;
  background: #1E1E2E;
}
.toolbar-title {
  font-size: 28rpx;
  color: #86EFAC;
  font-weight: 700;
}
.toolbar-actions { display: flex; gap: 16rpx; }
.toolbar-btn {
  font-size: 24rpx;
  color: #7DD3FC;
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
  background: rgba(125,211,252,0.15);
}
.preview-render {
  flex: 1;
  padding: 24rpx;
  overflow-y: auto;
  background: #fff;
}
.rich-content {
  width: 100%;
}
.preview-tip {
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  text-align: center;
  font-size: 22rpx;
  color: #999;
  background: #F8F7FC;
}

